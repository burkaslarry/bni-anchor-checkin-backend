# Copy to .env and fill in values.
# - Local testing: use run.sh (do NOT set SPRING_PROFILES_ACTIVE; optional: LOCAL_DB_USER, LOCAL_DB_PASSWORD).
# - Production: use run_prod.sh (sets profile=render; set DATABASE_* below).

# Production only (run_prod.sh): set these when using run_prod.sh
# SPRING_PROFILES_ACTIVE=render
# DATABASE_JDBC_URL=jdbc:postgresql://YOUR_HOST:5432/YOUR_DB?connectTimeout=5&socketTimeout=10
# DATABASE_USERNAME=your_db_user
# DATABASE_PASSWORD=your_db_password

# Local testing only (run.sh): optional overrides for application.properties
# LOCAL_DB_USER=your_local_pg_user
# LOCAL_DB_PASSWORD=your_local_pg_password

# Optional: DeepSeek API for guest/member matching
DEEPSEEK_API_KEY=

# Optional: Render sets PORT automatically for web services
# PORT=10000
